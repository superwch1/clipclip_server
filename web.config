<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <system.webServer>
        <handlers>
            <add name="ModuleCorrespond" path="server.js" verb="*" modules="iisnode" resourceType="Unspecified" />
        </handlers>
        <rewrite>
            <rules>
                <rule name="TheRule">
                    <match url="/*" />
                    <action type="Rewrite" url="server.js" />
                </rule>
            </rules>
        </rewrite>
    </system.webServer>
</configuration>
